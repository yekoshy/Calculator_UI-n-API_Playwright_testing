    "expectedResult": "Unknown token: scriptalertscript",
    "resultType": "security",
	  "api":{"expectedStatus": 400, "expectedResponseType": "INPUT_ERROR"	 }
  },
  {
    "id": "SEC-02",
    "description": "SQL Injection Attempt",
    "operand1": "' OR 1=1 --",
